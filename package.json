{
  "name": "radio-treasure-island",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build:css": "tailwindcss -i ./assets/css/input.css -o ./assets/css/site.css --minify",
    "watch:css": "tailwindcss -i ./assets/css/input.css -o ./assets/css/site.css --watch",
    "build": "npm run build:css && bundle exec jekyll build",
    "serve": "npm run build:css && bundle exec jekyll serve"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.4",
    "tailwindcss": "^4.2.4"
  }
}
